<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/adminDashbord.css">
</head>

<body class="flex min-h-screen">
  <aside id="sidebar"
    class="sidebar border-r border-gray-200 fixed inset-y-0 left-0 z-50 lg:relative lg:translate-x-0 transform -translate-x-full lg:block">
    <div class="p-4">
      <div class="relative mb-4">
        <input type="text" placeholder="Search"
          class="w-full bg-white border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" />
        <button class="absolute right-0 top-0 bottom-0 px-3 bg-neutral-800 text-white rounded-r">
          <i class="fas fa-search"></i>
        </button>
      </div>
    </div>

    <%- include('../partials/adminNav') %>
  </aside>

  <main class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <%- include('../partials/adminHeader') %>

    <main class="bg-gray-100 min-h-screen p-4 md:p-10">
      <div class="max-w-6xl mx-auto bg-white rounded-lg shadow-sm border border-gray-200">

        <div class="p-6 border-b border-gray-100 flex flex-col lg:flex-row lg:items-center justify-between gap-6">
          <h1 class="text-2xl font-semibold text-gray-800">Withdraw Summary</h1>

          <form method="GET">
            <div class="flex flex-wrap items-center gap-3 bg-gray-50 p-3 rounded-lg border border-gray-200">
              <div class="flex items-center gap-2">
                <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">From</label>
                <input type="date" name="from" value="<%= from %>"
                  class="bg-white px-3 py-1.5 border border-gray-300 rounded text-gray-600 text-sm">
              </div>

              <div class="flex items-center gap-2">
                <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">To</label>
                <input type="date" name="to" value="<%= to %>"
                  class="bg-white px-3 py-1.5 border border-gray-300 rounded text-gray-600 text-sm">
              </div>

              <button
                class="bg-yellow-500 text-white px-5 py-1.5 rounded text-sm font-semibold shadow-sm">
                Update
              </button>

              <a href="/adminWithdrawTransactions"
                class="bg-yellow-500 text-white px-5 py-1.5 rounded text-sm font-semibold shadow-sm">
                Reset
              </a>
            </div>
        </div>

        <div class="p-6 space-y-6">

          <!-- TOTAL -->
          <div class="bg-yellow-600 rounded-md p-8 text-white shadow-sm relative overflow-hidden">
            <div class="relative z-10">
              <div class="flex flex-col md:flex-row md:items-baseline gap-2">
                <span class="text-lg opacity-90 font-medium">Total Withdraw</span>
                <span class="text-4xl md:text-5xl font-bold tracking-tight">
                  ₹<%= totalWithdrawAmount.toLocaleString("en-IN") %>
                </span>
              </div>
              <p class="text-sm mt-2 opacity-90 font-medium">
                Total Transactions: <%= totalWithdrawCount %>
              </p>
            </div>
          </div>

          <!-- METHOD CARDS -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

            <!-- ADMIN -->
            <div class="group bg-white border border-gray-200 rounded-md p-6">
              <div class="flex items-start justify-between mb-4">
                <span class="text-gray-500 font-bold text-xs uppercase">Admin</span>
                <span class="text-2xl font-bold text-gray-800">
                  ₹<%= manualTotal.toLocaleString("en-IN") %>
                </span>
              </div>
              <p class="text-xs text-gray-400 font-semibold">
                Transactions: <%= manualCount %>
              </p>
            </div>

            <!-- GPAY -->
            <div class="group bg-white border border-gray-200 rounded-md p-6">
              <div class="flex items-start justify-between mb-4">
                <span class="text-gray-500 font-bold text-xs uppercase">GPay</span>
                <span class="text-2xl font-bold text-gray-800">
                  ₹<%= gpayTotal.toLocaleString("en-IN") %>
                </span>
              </div>
              <p class="text-xs text-gray-400 font-semibold">
                Transactions: <%= gpayCount %>
              </p>
            </div>

            <!-- PAYTM -->
            <div class="group bg-white border border-gray-200 rounded-md p-6">
              <div class="flex items-start justify-between mb-4">
                <span class="text-gray-500 font-bold text-xs uppercase">Paytm</span>
                <span class="text-2xl font-bold text-gray-800">
                  ₹<%= paytmTotal.toLocaleString("en-IN") %>
                </span>
              </div>
              <p class="text-xs text-gray-400 font-semibold">
                Transactions: <%= paytmCount %>
              </p>
            </div>

            <!-- PHONEPE -->
            <div class="group bg-white border border-gray-200 rounded-md p-6">
              <div class="flex items-start justify-between mb-4">
                <span class="text-gray-500 font-bold text-xs uppercase">PhonePe</span>
                <span class="text-2xl font-bold text-gray-800">
                  ₹<%= phonepeTotal.toLocaleString("en-IN") %>
                </span>
              </div>
              <p class="text-xs text-gray-400 font-semibold">
                Transactions: <%= phonepeCount %>
              </p>
            </div>

          </div>
        </div>
      </div>
    </main>

    <!-- TABLE -->
    <main class="bg-gray-100 p-4 md:p-8">
      <div class="max-w-6xl mx-auto bg-white p-6 rounded-lg shadow-sm border border-gray-200">

        <div class="overflow-x-auto">
          <table class="w-full border-collapse">
            <thead>
              <tr class="text-left border-y border-gray-300">
                <th class="p-3 border-x">S.No</th>
                <th class="p-3 border-x">Mobile</th>
                <th class="p-3 border-x">Username</th>
                <th class="p-3 border-x">Amount</th>
                <th class="p-3 border-x">Withdraw Type</th>
                <th class="p-3 border-x">Date</th>
              </tr>
            </thead>

            <tbody>
              <% if (withdraws.length > 0) { %>
                <% withdraws.forEach((tx, index) => { %>
                  <tr>
                    <td class="p-3 border-x">
                      <%= (currentPage - 1) * perPage + index + 1 %>
                    </td>
                    <td class="p-3 border-x">
                      <%= tx.user?.phoneNo || "-" %>
                    </td>
                    <td class="p-3 border-x">
                      <%= tx.user?.username || "-" %>
                    </td>
                    <td class="p-3 border-x font-medium">
                      ₹<%= Number(tx.amount).toFixed(2) %>
                    </td>
                    <td class="p-3 border-x">
                      <%= tx.gettingWithdrawManualy === "manual"
                            ? "Admin"
                            : (tx.withdrawUpi || "-") %>
                    </td>
                    <td class="p-3 border-x text-xs text-gray-500">
                      <%= new Date(tx.createdAt).toLocaleString() %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center p-4 text-gray-500">
                    No withdraw transactions found
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

      </div>
    </main>

  </main>
  <script src="/js/sidebar.js"></script>
</body>
</html>
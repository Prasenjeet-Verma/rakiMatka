<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/adminDashbord.css">

  <style>
    /* Custom scrollbar for the table wrapper */
    .custom-scrollbar::-webkit-scrollbar {
      height: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
      background: #f1f1f1;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #ccc;
      border-radius: 10px;
    }
  </style>

</head>

<body class="flex min-h-screen">
  <aside id="sidebar"
    class="sidebar border-r border-gray-200 fixed inset-y-0 left-0 z-50 lg:relative lg:translate-x-0 transform -translate-x-full lg:block">
    <div class="p-4">
      <div class="relative mb-4">
        <input type="text" placeholder="Search"
          class="w-full bg-white border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" />
        <button class="absolute right-0 top-0 bottom-0 px-3 bg-neutral-800 text-white rounded-r">
          <i class="fas fa-search"></i>
        </button>
      </div>
    </div>

    <!-- ============================= Nav is here ============================ -->

    <%- include('../partials/adminNav') %>
  </aside>

  <main class="flex-1 flex flex-col min-w-0 overflow-hidden">

    <!-- ============================= Header is here ============================ -->
    <%- include('../partials/adminHeader') %>

      <header class="bg-white h-14 flex items-center justify-between px-4 border-b border-gray-200">
      </header> <!-- header overflow done -->

      <!-- ==================================== Body Start Here ========================================= -->
      <main class="p-4 md:p-8">

        <div class="max-w-6xl mx-auto bg-white shadow-md rounded-sm border border-gray-200">
          <div class="border-b border-gray-200 px-4 py-2 bg-gray-50">
            <h1 class="text-sm font-semibold text-gray-700">Main Settings</h1>
          </div>

          <form method="post" action="/admin/main-settings" class="p-4 space-y-4">

            <div class="grid grid-cols-1 gap-4">

              <div class="space-y-1">
                <label class="block text-xs font-bold text-gray-800">Homescreen text</label>
                <input type="text" value="<%= mainSettings.homescreenText %>" name="homescreenText"
                  class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
              </div>

              <div class="space-y-1">
                <label class="block text-xs font-bold text-gray-800">Signup reward</label>
                <input type="number" value="<%= mainSettings.signupReward %>" name="signupReward"
                  class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
              </div>

              <div class="space-y-1">
                <label class="block text-xs font-bold text-gray-800">Min deposit</label>
                <input type="number" value="<%= mainSettings.minDeposit %>" name="minDeposit"
                  class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="space-y-1">
                  <label class="block text-xs font-bold text-gray-800">Min withdraw</label>
                  <input type="number" value="<%= mainSettings.minWithdraw %>" name="minWithdraw"
                    class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                </div>
                <div class="space-y-1">
                  <label class="block text-xs font-bold text-gray-800">Max withdraw</label>
                  <input type="number" value="<%= mainSettings.maxWithdraw %>" name="maxWithdraw"
                    class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                </div>
              </div>


              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="space-y-1">
                  <label class="block text-xs font-bold text-gray-800">Min bet</label>
                  <input type="number" value="<%= mainSettings.minBet %>" name="minBet"
                    class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                </div>
                <div class="space-y-1">
                  <label class="block text-xs font-bold text-gray-800">Max bet</label>
                  <input type="number" value="<%= mainSettings.maxBet %>" name="maxBet"
                    class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                </div>
              </div>

              <div class="space-y-1">
                <label class="block text-xs font-bold text-gray-800">Share link</label>
                <input type="text" value="<%= mainSettings.shareLink %>" name="shareLink"
                  class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm">
              </div>

              <div class="space-y-1">
                <label class="block text-xs font-bold text-gray-800">Withdraw video link</label>
                <input type="text" value="<%= mainSettings.withdrawVideoLink %>" name="withdrawVideoLink"
                  class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm">
              </div>


              <div class="space-y-1">
                <label class="block text-xs font-bold text-gray-800">Withdraw disable</label>

                <select name="withdrawDisabled"
                  class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm bg-white">
                  <option value="false" <%=mainSettings?.withdrawDisabled===false ? "selected" : "" %>>Disable</option>
                  <option value="true" <%=mainSettings?.withdrawDisabled===true ? "selected" : "" %>>Enable</option>
                </select>
              </div>


            </div>

            <div class="pt-2">
              <button type="submit"
                class="bg-yellow-500 hover:bg-yellow-600 text-white font-medium py-1.5 px-4 rounded text-sm transition-colors">
                Update
              </button>
            </div>

          </form>
        </div>

      </main>

      <!-- ==================================== Body End Here ========================================= -->
  </main>
  <script src="/js/sidebar.js"></script>
</body>

</html>
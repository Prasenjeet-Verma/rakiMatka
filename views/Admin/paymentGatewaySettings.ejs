<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/adminDashbord.css" />

  <style>
    /* Custom scrollbar for the table wrapper */
    .custom-scrollbar::-webkit-scrollbar {
      height: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
      background: #f1f1f1;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #ccc;
      border-radius: 10px;
    }
  </style>
</head>

<body class="flex min-h-screen">
  <aside id="sidebar"
    class="sidebar border-r border-gray-200 fixed inset-y-0 left-0 z-50 lg:relative lg:translate-x-0 transform -translate-x-full lg:block">
    <div class="p-4">
      <div class="relative mb-4">
        <input type="text" placeholder="Search"
          class="w-full bg-white border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" />
        <button class="absolute right-0 top-0 bottom-0 px-3 bg-neutral-800 text-white rounded-r">
          <i class="fas fa-search"></i>
        </button>
      </div>
    </div>

    <!-- ============================= Nav is here ============================ -->

    <%- include('../partials/adminNav') %>
  </aside>

  <main class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <!-- ============================= Header is here ============================ -->
    <%- include('../partials/adminHeader') %>

      <header class="bg-white h-14 flex items-center justify-between px-4 border-b border-gray-200"></header>
      <!-- header overflow done -->

      <!-- ==================================== Body Start Here ========================================= -->
      <!doctype html>
      <html lang="en">

      <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Payment Gateway Settings</title>
        <script src="https://cdn.tailwindcss.com"></script>
      </head>

      <body class="bg-gray-100 p-4 md:p-8 font-sans">
        <div class="max-w-6xl mx-auto bg-white shadow-sm border border-gray-200 rounded-sm">
          <div class="border-b border-gray-200 p-4">
            <h1 class="text-gray-700 text-lg font-medium">
              Payment Gateway Settings
            </h1>
          </div>

          <div class="p-4 space-y-6">
            <div class="border border-gray-200 rounded-sm">
              <div class="bg-gray-50 p-3 border-b border-gray-200">
                <h2 class="font-bold text-gray-800 text-sm">
                  Manage UPI Gateway
                </h2>
              </div>
              <div class="p-4 space-y-4">
                <p class="text-gray-600 text-sm">
                  UPI Gateway is QR Code based gateway, you can create account
                  on
                  <a href="#" class="text-blue-500 underline">https://upigateway.com/</a>
                </p>

                <form action="/admin/payment-gateway-settings" method="POST">
                  <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Upi gateway</label>
                    <select name="upiGateway"
                      class="w-full border border-gray-300 rounded p-2 text-sm bg-white focus:outline-none focus:ring-1 focus:ring-blue-500">
                      <option value="Select" <%=settings.upiGateway==="Select" ? "selected" : "" %>>Select</option>
                      <option value="Enable" <%=settings.upiGateway==="Enable" ? "selected" : "" %>>Enable</option>
                      <option value="Disable" <%=settings.upiGateway==="Disable" ? "selected" : "" %>>Disable</option>
                    </select>
                  </div>

                  <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Upi gateway key</label>
                    <input type="text" name="upiGatewayKey" value="<%= settings.upiGatewayKey || '' %>"
                      class="w-full border border-gray-300 rounded p-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" />
                  </div>

                  <div class="border border-gray-200 rounded-sm mt-4">
                    <div class="bg-gray-50 p-3 border-b border-gray-200">
                      <h2 class="font-bold text-gray-800 text-sm">Direct UPI Gateway</h2>
                    </div>
                    <div class="p-4 space-y-4">
                      <p class="text-[11px] text-gray-500 leading-relaxed italic">
                        Direct UPI Gateway is an unofficial UPI gateway, you can enter your merchant upi id and
                        respective app will open the payment with upi id, but very few upi id works with direct upi
                        system, and there's some chances that fake payment will be accepted mostly this issue is common
                        with phonepe. We recommend you to enable direct verify option so payment request will receive to
                        admin and only after you accept payment will add to user's wallet.
                      </p>
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                          <label class="block text-[12px] font-bold text-gray-700 mb-1">Direct upi</label>
                          <select name="directUpi" class="w-full border border-gray-300 rounded p-2 text-sm bg-white">
                            <option value="Select" <%=settings.directUpi==="Select" ? "selected" : "" %>>Select</option>
                            <option value="Enable" <%=settings.directUpi==="Enable" ? "selected" : "" %>>Enable</option>
                            <option value="Disable" <%=settings.directUpi==="Disable" ? "selected" : "" %>>Disable
                            </option>
                          </select>
                        </div>
                        <div>
                          <label class="block text-[12px] font-bold text-gray-700 mb-1">Direct gpay id</label>
                          <input type="text" name="directGpayId" value="<%= settings.directGpayId || '' %>"
                            class="w-full border border-gray-300 rounded p-2 text-sm" />
                        </div>
                        <div>
                          <label class="block text-[12px] font-bold text-gray-700 mb-1">Direct phonepe id</label>
                          <input type="text" name="directPhonepeId" value="<%= settings.directPhonepeId || '' %>"
                            class="w-full border border-gray-300 rounded p-2 text-sm" />
                        </div>
                        <div>
                          <label class="block text-[12px] font-bold text-gray-700 mb-1">Direct paytm id</label>
                          <input type="text" name="directPaytmId" value="<%= settings.directPaytmId || '' %>"
                            class="w-full border border-gray-300 rounded p-2 text-sm" />
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="border border-gray-200 rounded-sm mt-4">
                    <div class="bg-gray-50 p-3 border-b border-gray-200">
                      <h2 class="font-bold text-gray-800 text-sm">Common Settings</h2>
                    </div>
                    <div class="p-4 space-y-4">
                      <p class="text-gray-600 text-sm italic">
                        These settings are common for every payment gateway or
                        deposit screen
                      </p>
                      <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Quick deposit amounts</label>
                        <input type="text" name="quickDepositAmounts"
                          value="<%= settings.quickDepositAmounts || '200,300,500,1000,2500,5000,10000,25000,50000' %>"
                          class="w-full border border-gray-300 rounded p-2 text-sm" />
                      </div>
                      <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Gateway window</label>
                        <select name="gatewayWindow" class="w-full border border-gray-300 rounded p-2 text-sm bg-white">
                          <option value="Inside App" <%=settings.gatewayWindow==="Inside App" ? "selected" : "" %>
                            >Inside App</option>
                          <option value="Browser" <%=settings.gatewayWindow==="Browser" ? "selected" : "" %>>Browser
                          </option>
                        </select>
                      </div>
                    </div>
                  </div>

                  <div class="pt-2">
                    <button type="submit"
                      class="bg-[#f0ad4e] hover:bg-orange-500 text-white px-4 py-2 rounded text-sm font-medium transition-colors">Update</button>
                  </div>
                </form>
              </div>
            </div>
      </body>

      </html>
      <!-- ==================================== Body End Here ========================================= -->
  </main>
  <script src="/js/sidebar.js"></script>
</body>

</html>
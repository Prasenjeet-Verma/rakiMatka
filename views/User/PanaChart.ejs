<!DOCTYPE html>
<html>
<head>
  <title><%= gameName %> - Weekly Panel Chart</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/slider.css">
</head>

<body class="bg-gray-100">

  <!-- HEADER -->
  <header class="bg-white shadow-md px-4 py-3 flex justify-between items-center fixed top-0 left-0 w-full z-50">
    <div class="flex items-center gap-2 w-20">
      <img src="<%= logo.logoUrl %>" alt="shrirammatka" class="w-full object-contain">
    </div>

    <div class="flex items-center gap-3">
      <a href="/login">
        <button
          class="px-4 py-1 border border-green-700 text-green-700 rounded-full hover:bg-green-700 hover:text-white transition text-sm sm:text-base">
          Login
        </button>
      </a>
      <a href="/signup">
        <button
          class="px-4 py-1 bg-green-700 text-white rounded-full hover:bg-green-800 transition text-sm sm:text-base">
          Sign Up
        </button>
      </a>
    </div>
  </header>

  <!-- CONTENT WRAPPER -->
  <div class="pt-24 px-2 sm:px-4">

    <h2 class="text-xl sm:text-3xl font-bold text-center mb-6 text-blue-800">
      <%= gameName %> DAY PANEL CHART
    </h2>

    <!-- TABLE WRAPPER -->
    <div class="w-full overflow-x-auto">

      <table class="min-w-[900px] w-full border border-blue-700 text-center">

        <!-- Header -->
        <thead>
          <tr class="bg-yellow-400 text-black font-bold text-sm sm:text-lg">
            <th class="border border-blue-700 p-2 sm:p-3">Date</th>
            <th class="border border-blue-700 p-2 sm:p-3">Mon</th>
            <th class="border border-blue-700 p-2 sm:p-3">Tue</th>
            <th class="border border-blue-700 p-2 sm:p-3">Wed</th>
            <th class="border border-blue-700 p-2 sm:p-3">Thu</th>
            <th class="border border-blue-700 p-2 sm:p-3">Fri</th>
            <th class="border border-blue-700 p-2 sm:p-3">Sat</th>
            <th class="border border-blue-700 p-2 sm:p-3">Sun</th>
          </tr>
        </thead>

        <tbody>

          <% const days = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"]; %>

          <% finalWeeks.forEach(week => { %>

            <tr class="bg-orange-200">

              <!-- Week Date -->
              <td class="border border-blue-700 p-2 sm:p-3 font-semibold text-xs sm:text-base whitespace-nowrap">
                <%= new Date(week.startDate).toLocaleDateString("en-GB") %>
                    To
                    <%= new Date(week.endDate).toLocaleDateString("en-GB") %>
              </td>

              <% days.forEach(day => { 
                   const dayData = week.days[day];
              %>

                <td class="border border-blue-700 p-2 sm:p-3">

                  <% if(dayData && dayData.OPEN && dayData.CLOSE){ %>

                    <div class="text-lg sm:text-2xl font-bold text-black">
                      <%= dayData.OPEN.digit %><%= dayData.CLOSE.digit %>
                    </div>

                    <div class="text-[10px] sm:text-xs text-gray-700 mt-1">
                      <%= dayData.OPEN.panna %> |
                      <%= dayData.CLOSE.panna %>
                    </div>

                  <% } else { %>

                    <div class="text-gray-400 text-sm">--</div>

                  <% } %>

                </td>

              <% }) %>

            </tr>

          <% }) %>

        </tbody>

      </table>

    </div>

  </div>

</body>
</html>
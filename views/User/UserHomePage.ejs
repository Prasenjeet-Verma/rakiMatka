<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ratan Matka</title>

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="/js/rendomsidebar.js"></script>

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/slider.css">
</head>

<body class="bg-gray-100">

  <!-- HEADER -->
  <header class="bg-white shadow-md px-4 py-3 flex justify-between items-center"
    style="position: fixed; z-index: 400; width: 100%;">
    <div class="flex items-center gap-2" style="width: 5rem;">
      <img src="/images/logo/logo.png" alt="shrirammatka">
    </div>

    <div class="flex items-center gap-3">
      <a href="/login">
        <button
          class="px-4 py-1 border border-green-700 text-green-700 rounded-full hover:bg-green-700 hover:text-white transition">
          Login
        </button>
      </a>
      <a href="/signup">
        <button class="px-4 py-1 bg-green-700 text-white rounded-full hover:bg-green-800 transition">
          Sign Up
        </button>
      </a>
    </div>
  </header>

  <!-- Overflow -->

  <overflow class="bg-white shadow-md px-4 py-3 flex justify-between items-center">
    <div class="flex items-center gap-2" style="width: 5rem;">
      <img src="<%= logo.logoUrl %>" alt="">
    </div>
  </overflow>


  <!-- HERO SECTION -->
  <!-- ++++++++++++++++++++++++++++++++++++++++++++++++++ -->
  <div class="mbanner">


    <div class="mx-auto">

      <!-- Banner Wrapper -->
      <div class="banner-container shadow-3xl">

        <!-- Slide 1 -->
        <div class="banner-slide active" data-index="0">
          <img src="<%= slider?.sliderImage1 || '/images/banner/b1.png' %>" class="w-full h-full object-cover"
            alt="Slide 1">
        </div>

        <!-- Slide 2 -->
        <div class="banner-slide" data-index="1">
          <img src="<%= slider?.sliderImage2 || '/images/banner/b2.png' %>" class="w-full h-full object-cover"
            alt="Slide 2">
        </div>

        <!-- Slide 3 -->
        <div class="banner-slide" data-index="2">
          <img src="<%= slider?.sliderImage3 || '/images/banner/b3.png' %>" class="w-full h-full object-cover"
            alt="Slide 3">
        </div>


        <!-- Navigation Buttons -->
        <div class="absolute inset-0 flex items-center justify-between p-4 z-20">
          <button id="prevBtn"
            class="transition shadow-lg opacity-70 hover:opacity-100 disabled:opacity-30 disabled:cursor-not-allowed">
          </button>
          <button id="nextBtn"
            class=" transition shadow-lg opacity-70 hover:opacity-100 disabled:opacity-30 disabled:cursor-not-allowed">
          </button>
        </div>

      </div>

      <!-- Pagination Dots -->
      <div id="pagination" class="flex justify-center space-x-2 mt-4">
        <!-- Dots will be generated here by JS -->
      </div>

    </div>

  </div>


  <!-- ++++++++++++++++++++++++++++++++++++++++++++++++++ -->

  <!-- DOWNLOAD APP -->
  <div class="px-6 mt-6">
   <% if (mainSetting?.downloadLink) { %>
  <a 
    href="<%= mainSetting.downloadLink %>" 
    target="_blank"
    class="w-full bg-green-700 text-white py-3 rounded-full text-lg font-semibold flex items-center justify-center gap-2 hover:bg-green-800 transition"
  >
    <i class="fab fa-android"></i> Download App
  </a>
<% } %>
  </div>

  <!-- CONTACT -->
  <section class="mt-8 text-center">
    <h2 class="text-xl font-semibold mb-4">Contact Us</h2>

    <div class="flex justify-center gap-4 px-6">
      <a href="https://wa.me/<%= contact.whatsappNumber %>" target="_blank"
        class="flex items-center gap-2 px-6 py-2 border border-green-500 text-green-500 rounded-full hover:bg-green-500 hover:text-white transition">
        <i class="fab fa-whatsapp"></i> WhatsApp
      </a>

      <a href="tel:<%= contact.callNumber %>"
        class="flex items-center gap-2 px-6 py-2 border border-blue-700 text-blue-700 rounded-full hover:bg-blue-700 hover:text-white transition">
        <i class="fas fa-phone"></i> Call
      </a>

    </div>

    <div class="flex justify-center gap-4 px-6 mt-4">
      <a href="<%= contact.telegramGroupLink %>" target="_blank"
        class="flex items-center gap-2 px-6 py-2 border border-blue-500 text-blue-500 rounded-full hover:bg-blue-500 hover:text-white transition">
        <i class="fab fa-telegram"></i> Telegram
      </a>
    </div>
  </section>

  <!-- CREDIBILITY -->
  <section class="mt-10 bg-white py-6">
    <div style="display: flex; justify-content: center; align-items: center;">
      <h3 style="border-radius: 15px; width: 80%; padding: 0.5rem;"
        class="text-center font-semibold mb-6 text-white bg-green-700">SHRIRAM MATKA CREDIBILITY</h3>
    </div>

    <div class="flex justify-around text-center">
      <div>
        <i class="fas fa-users text-green-700 text-3xl mb-2"></i>
        <h4 class="font-bold">10 Million+</h4>
        <p class="text-sm text-gray-500">Players</p>
      </div>

      <div>
        <i class="fas fa-gamepad text-green-700 text-3xl mb-2"></i>
        <h4 class="font-bold">100+</h4>
        <p class="text-sm text-gray-500">Games</p>
      </div>

      <div>
        <i class="fas fa-money-bill-wave text-green-700 text-3xl mb-2"></i>
        <h4 class="font-bold">1 Cr</h4>
        <p class="text-sm text-gray-500">Daily Winning</p>
      </div>
    </div>
  </section>

  <!--  ================================== Game Rules Start -->

  <section class="bg-gray-100">

    <div class="max-w-sm mx-auto mt-6 px-3">

      <!-- TITLE -->
      <h1 class="text-2xl font-bold text-center">
        Game <span class="text-green-700">Rates</span>
      </h1>
      <p class="text-center text-gray-500 text-sm mt-1">
        We Have Best Game Rates For You
      </p>

      <!-- TABS -->
      <div class="flex border rounded-md overflow-hidden mt-4 text-sm">
        <div id="tab-main" class="flex-1 text-center py-2 font-medium cursor-pointer bg-blue-700 text-white">
          Main Market
        </div>

        <div id="tab-star" class="flex-1 text-center py-2 font-medium cursor-pointer bg-gray-100 text-gray-700">
          Star Line
        </div>

        <div id="tab-gali" class="flex-1 text-center py-2 font-medium cursor-pointer bg-gray-100 text-gray-700">
          Jackpot
        </div>
      </div>


      <!-- MAIN MARKET -->
      <div id="mainMarketRates" class="space-y-3 mt-5">

        <% normalRates.forEach(rate=> { %>

          <div class="flex justify-between items-center bg-green-600 p-3 rounded-lg shadow border-l-4 border-green-800">
            <span class="text-sm text-white">
              <%= rate.gameType %>
            </span>
            <span class="text-white font-semibold text-sm">
              <%= rate.betAmount %> KA <%= rate.profitAmount %>
            </span>
          </div>

          <% }) %>

      </div>

      <!-- STAR LINE -->
      <div id="starLineRates" class="hidden space-y-3 mt-5">

        <% starlineRates.forEach(rate=> { %>

          <div class="flex justify-between items-center bg-green-600 p-3 rounded-lg shadow border-l-4 border-green-800">
            <span class="text-sm text-white">
              <%= rate.gameType %>
            </span>
            <span class="text-white font-semibold text-sm">
              <%= rate.betAmount %> KA <%= rate.profitAmount %>
            </span>
          </div>

          <% }) %>

      </div>

      <!-- GALI DESAWAR -->
      <div id="galiDesawarRates" class="hidden space-y-3 mt-5">

        <% jackpotRates.forEach(rate=> { %>

          <div class="flex justify-between items-center bg-green-600 p-3 rounded-lg shadow border-l-4 border-green-800">
            <span class="text-sm text-white">
              <%= rate.gameType %>
            </span>
            <span class="text-white font-semibold text-sm">
              <%= rate.betAmount %> KA <%= rate.profitAmount %>
            </span>
          </div>

          <% }) %>

      </div>

    </div>
  </section>
  <div id="mainMarket">
    <main class="bg-gray-100">

      <section class="max-w-7xl mx-auto px-4 py-6">

        <!-- TITLE -->
        <h2 class="text-xl font-semibold mb-4">Available Games</h2>

        <!-- GRID -->
        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-4">

          <!-- normal games  -->
          <% finalGames.forEach(game=> { %>

            <div style="border: 2px solid green;" class="bg-green-100 rounded-lg shadow p-4">
              <h3 class="font-semibold text-center mb-2">
                <%= game.gameName %>
              </h3>

              <div class="text-xs text-gray-600 flex justify-center mb-1">
                <div>
                  <div class="text-amber-500">
                    <%= game.openTime %> - <%= game.closeTime %>
                  </div>
                </div>
              </div>

              <p class="text-sm text-center text-green-600 my-2">

                <!-- OPEN PANNA -->
                <%= game.openResult ? game.openResult.panna : "xxx" %>

                  -

                  <!-- JODI (OpenDigit + CloseDigit) -->
                  <%= game.openResult ? game.openResult.digit : "x" %>
                    <%= game.closeResult ? game.closeResult.digit : "x" %>

                      -

                      <!-- CLOSE PANNA -->
                      <%= game.closeResult ? game.closeResult.panna : "xxx" %>

              </p>

              <div class="flex justify-center mb-3">
                <span class="bg-red-500 text-white text-xs px-3 py-1 rounded-full">
                  <span class="<%= game.status === 'CLOSED'
      ? 'bg-red-500'
      : 'bg-yellow-400' %> 
      text-white text-xs px-3 py-1 rounded-full">

                    <%= game.status %>
                  </span>
                </span>
              </div>

              <div class="flex justify-center gap-2">
                <a href="/jodi-chart/<%= game.gameName %>"
   class="border border-green-700 text-green-700 text-xs px-3 py-1 rounded text-center">
   Jodi Chart
</a>
                <a href="/pana-chart/<%= game.gameName %>"
                  class="border border-green-700 text-green-700 text-xs px-3 py-1 rounded text-center">
                  Pana Chart
                </a>
              </div>
            </div>

            <% }) %>

        </div>
      </section>

    </main>
  </div>

  <div id="galiDesawar" class="hidden">
    <main class="bg-gray-100">

      <section class="max-w-7xl mx-auto px-4 py-6">

        <!-- TITLE -->
        <h2 class="text-xl font-semibold mb-4">Available Games</h2>

        <!-- GRID -->
        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-4">

          <!-- normal games  -->
          <% finalGames.forEach(game=> { %>

            <div style="border: 2px solid green;" class="bg-green-100 rounded-lg shadow p-4">
              <h3 class="font-semibold text-center mb-2">
                <%= game.gameName %>
              </h3>

              <div class="text-xs text-gray-600 flex justify-center mb-1">
                <div>
                  <div class="text-amber-500">
                    <%= game.openTime %> - <%= game.closeTime %>
                  </div>
                </div>
              </div>

              <p class="text-sm text-center text-green-600 my-2">

                <!-- OPEN PANNA -->
                <%= game.openResult ? game.openResult.panna : "xxx" %>

                  -

                  <!-- JODI (OpenDigit + CloseDigit) -->
                  <%= game.openResult ? game.openResult.digit : "x" %>
                    <%= game.closeResult ? game.closeResult.digit : "x" %>

                      -

                      <!-- CLOSE PANNA -->
                      <%= game.closeResult ? game.closeResult.panna : "xxx" %>

              </p>

              <div class="flex justify-center mb-3">
                <span class="bg-red-500 text-white text-xs px-3 py-1 rounded-full">
                  <span class="<%= game.status === 'CLOSED'
      ? 'bg-red-500'
      : 'bg-yellow-400' %> 
      text-white text-xs px-3 py-1 rounded-full">

                    <%= game.status %>
                  </span>
                </span>
              </div>

              <div class="flex justify-center gap-2">
                <a href="/jodi-chart/<%= game.gameName %>"
   class="border border-green-700 text-green-700 text-xs px-3 py-1 rounded text-center">
   Jodi Chart
</a>
                <a href="/pana-chart/<%= game.gameName %>"
                  class="border border-green-700 text-green-700 text-xs px-3 py-1 rounded text-center">
                  Pana Chart
                </a>
              </div>
            </div>

            <% }) %>

        </div>
      </section>

    </main>
  </div>

  <div id="starLineGames" class="hidden">
    <main class="bg-gray-100">

      <section class="max-w-7xl mx-auto px-4 py-6">

        <!-- TITLE -->
        <h2 class="text-xl font-semibold mb-4">Available Games</h2>

        <!-- GRID -->
        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-4">

          <!-- normal games  -->
          <% finalGames.forEach(game=> { %>

            <div style="border: 2px solid green;" class="bg-green-100 rounded-lg shadow p-4">
              <h3 class="font-semibold text-center mb-2">
                <%= game.gameName %>
              </h3>

              <div class="text-xs text-gray-600 flex justify-center mb-1">
                <div>
                  <div class="text-amber-500">
                    <%= game.openTime %> - <%= game.closeTime %>
                  </div>
                </div>
              </div>

              <p class="text-sm text-center text-green-600 my-2">

                <!-- OPEN PANNA -->
                <%= game.openResult ? game.openResult.panna : "xxx" %>

                  -

                  <!-- JODI (OpenDigit + CloseDigit) -->
                  <%= game.openResult ? game.openResult.digit : "x" %>
                    <%= game.closeResult ? game.closeResult.digit : "x" %>

                      -

                      <!-- CLOSE PANNA -->
                      <%= game.closeResult ? game.closeResult.panna : "xxx" %>

              </p>

              <div class="flex justify-center mb-3">
                <span class="bg-red-500 text-white text-xs px-3 py-1 rounded-full">
                  <span class="<%= game.status === 'CLOSED'
      ? 'bg-red-500'
      : 'bg-yellow-400' %> 
      text-white text-xs px-3 py-1 rounded-full">

                    <%= game.status %>
                  </span>
                </span>
              </div>

              <div class="flex justify-center gap-2">
               <a href="/jodi-chart/<%= game.gameName %>"
   class="border border-green-700 text-green-700 text-xs px-3 py-1 rounded text-center">
   Jodi Chart
</a>
                <a href="/pana-chart/<%= game.gameName %>"
                  class="border border-green-700 text-green-700 text-xs px-3 py-1 rounded text-center">
                  Pana Chart
                </a>
              </div>
            </div>

            <% }) %>

        </div>
      </section>

    </main>

  </div>

  <script src="/js/traggle.js"></script>
</body>

</html>